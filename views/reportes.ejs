<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        Reportes
    </title>

    <link rel="stylesheet" href="/css/style.css">

    <style>
        body {
            background: #0f0f0f;
            color: white;
            font-family: Arial, sans-serif;
            display: flex;
        }

        .main-content {
            flex: 1;
            padding: 30px;
        }

        .title {
            font-size: 30px;
            margin-bottom: 25px;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: #1c1c1c;
            padding: 25px;
            border-radius: 15px;
            border: 1px solid #2d2d2d;
        }

        .card h3 {
            color: #999;
            margin-bottom: 10px;
            font-size: 14px;
        }

        .card p {
            font-size: 32px;
            font-weight: bold;
        }

        .section {
            background: #1c1c1c;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 25px;
            border: 1px solid #2d2d2d;
        }

        .section h2 {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 14px;
            border-bottom: 1px solid #333;
            text-align: left;
        }

        th {
            color: #999;
        }

        .alerta {
            color: #ff4d4d;
            font-weight: bold;
        }
    </style>

</head>

<body>

    <%- include('partials/sidebar', { page: 'reportes' }) %>

        <div class="main-content">

            <h1 class="title">
                📊 Reportes del Sistema
            </h1>


            <div class="cards">

                <div class="card">
                    <h3>Total Ventas</h3>
                    <p>
                        $<%= ventas.total_ventas || 0 %>
                    </p>
                </div>

                <div class="card">
                    <h3>Tickets Generados</h3>
                    <p>
                        <%= ventas.total_tickets || 0 %>
                    </p>
                </div>

            </div>


            <div class="section">

                <h2>
                    🔥 Productos Más Vendidos
                </h2>

                <table>

                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Total Vendido</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% productosVendidos.forEach(p=> { %>

                            <tr>
                                <td>
                                    <%= p.nombre %>
                                </td>
                                <td>
                                    <%= p.total_vendido %>
                                </td>
                            </tr>

                            <% }) %>

                    </tbody>

                </table>

            </div>


            <div class="section">

                <h2>
                    ⚠️ Productos con Stock Bajo
                </h2>

                <table>

                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Stock</th>
                            <th>Mínimo</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% stockBajo.forEach(s=> { %>

                            <tr>
                                <td>
                                    <%= s.nombre %>
                                </td>
                                <td class="alerta">
                                    <%= s.cantidad %>
                                </td>
                                <td>
                                    <%= s.stock_minimo %>
                                </td>
                            </tr>

                            <% }) %>

                    </tbody>

                </table>

            </div>


            <div class="section">

                <h2>
                    📋 Últimos Movimientos
                </h2>

                <table>

                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Usuario</th>
                            <th>Tipo</th>
                            <th>Cantidad</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% movimientos.forEach(m=> { %>

                            <tr>

                                <td>
                                    <%= m.producto %>
                                </td>

                                <td>
                                    <%= m.usuario %>
                                </td>

                                <td>
                                    <%= m.tipo_movimiento %>
                                </td>

                                <td>
                                    <%= m.cantidad %>
                                </td>

                                <td>
                                    <%= new Date(m.fecha_hora).toLocaleString('es-CO') %>
                                </td>

                            </tr>

                            <% }) %>

                    </tbody>

                </table>

            </div>


            <div class="section">

                <h2>
                    🚨 Alertas Activas
                </h2>

                <table>

                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Mensaje</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% alertas.forEach(a=> { %>

                            <tr>

                                <td>
                                    <%= a.producto %>
                                </td>

                                <td class="alerta">
                                    <%= a.mensaje %>
                                </td>

                                <td>
                                    <%= new Date(a.fecha).toLocaleString('es-CO') %>
                                </td>

                            </tr>

                            <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

</body>

</html>