<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Solo Frenos - Iniciar Sesión</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            background-color: #0f0f0f;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-image: linear-gradient(rgba(10, 10, 10, 0.7), rgba(15, 15, 15, 0.9)), url('../img/fondo_login.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .login-container {
            text-align: center;
            width: 100%;
            max-width: 400px;
        }

        .login-logo {
            margin-bottom: 20px;
        }

        .login-logo h1 {
            font-size: 2rem;
            letter-spacing: 2px;
            margin-bottom: 5px;
        }

        .login-logo p {
            color: var(--text-muted);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .login-box {
            background-color: rgba(25, 25, 25, 0.95);
            padding: 30px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            text-align: left;
        }

        .login-box h2 {
            font-size: 1.3rem;
            margin-bottom: 5px;
        }

        .login-box p.subtitle {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.9rem;
            color: #ddd;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper input {
            width: 100%;
            padding: 12px 15px;
            padding-left: 40px;
            background-color: #111;
            border: 1px solid var(--border-color);
            color: white;
            border-radius: 8px;
            outline: none;
            transition: border 0.3s;
        }

        .input-wrapper input:focus {
            border-color: var(--primary-red);
        }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        .options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            font-size: 0.85rem;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            background-color: var(--primary-red);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s;
        }

        .btn-login:hover {
            background-color: var(--primary-red-hover);
        }

        .error-msg {
            color: var(--primary-red);
            font-size: 0.85rem;
            margin-bottom: 15px;
            text-align: center;
        }
    </style>
</head>

<body>

    <div class="login-container">
        <div class="login-logo">
            <img src="../img/Logo.png" alt="Solo Frenos El Mechudo" style="max-width: 250px; margin-bottom: 10px;">
            <p>Sistemas de Seguridad Automotriz</p>
        </div>

        <div class="login-box">
            <h2>Bienvenido al Panel</h2>
            <p class="subtitle">Ingrese sus credenciales para acceder</p>

            <% if (locals.error) { %>
                <div class="error-msg">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/login" method="POST">
                        <div class="form-group">
                            <label>Usuario</label>
                            <div class="input-wrapper">
                                <i>👤</i>
                                <input type="text" name="usuario" placeholder="admin_taller" required>
                            </div>
                        </div>

                        <div class="form-group">
                        <div style="display: flex; justify-content: space-between;">
                            <label>Contraseña</label>
                            <a href="javascript:alert('Por motivos de seguridad, debes comunicarte con Soporte Técnico para restablecer tu contraseña.');" style="color: var(--primary-red); font-size: 0.8rem;">¿Olvidó su clave?</a>
                        </div>
                            <div class="input-wrapper">
                                <i>🔒</i>
                                <input type="password" name="password" placeholder="••••••••" required>
                            </div>
                        </div>

                        <div class="options">
                            <label><input type="checkbox" name="remember"> Recordar mi sesión</label>
                        </div>

                        <button type="submit" class="btn-login">Iniciar Sesión ➔</button>
                    </form>
        </div>
    </div>

</body>

</html>