<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>POS - Solo Frenos</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .pos-container { display: flex; height: calc(100vh - 70px); }
        .products-section { flex: 2; padding: 20px; overflow-y: auto; border-right: 1px solid var(--border-color); }
        .ticket-section { flex: 1; min-width: 350px; background: #1a1a1a; display: flex; flex-direction: column; }
        
        .filters { display: flex; gap: 10px; margin-bottom: 20px; overflow-x: auto; padding-bottom: 10px; }
        .filter-btn { padding: 8px 16px; background: #2c2c2c; border: 1px solid #444; border-radius: 20px; color: white; cursor: pointer; white-space: nowrap; }
        .filter-btn.active { background: var(--primary-red); border-color: var(--primary-red); }

        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px; }
        .product-card { background: var(--bg-panel); border: 1px solid var(--border-color); border-radius: 10px; padding: 15px; text-align: center; display: flex; flex-direction: column; justify-content: space-between; height: 220px; }
        .product-img { height: 80px; background: #333; border-radius: 8px; margin-bottom: 10px; display: flex; align-items: center; justify-content: center; font-size: 2rem; color: #555; }
        .product-title { font-size: 0.9rem; font-weight: bold; margin-bottom: 5px; text-align: left; }
        .product-price { color: var(--primary-red); font-weight: bold; font-size: 1.1rem; text-align: left; }
        .product-stock { font-size: 0.75rem; color: var(--text-muted); text-align: left; margin-bottom: 10px; }
        .add-btn { background: var(--primary-red); color: white; border: none; border-radius: 50%; width: 30px; height: 30px; font-size: 1.2rem; cursor: pointer; align-self: flex-end; }
        .add-btn:hover { background: var(--primary-red-hover); }

        /* Ticket Section */
        .ticket-header { padding: 20px; border-bottom: 1px solid #333; display: flex; justify-content: space-between; align-items: center; }
        .ticket-header h2 { font-size: 1.2rem; display: flex; align-items: center; gap: 10px; }
        
        .client-section { padding: 20px; border-bottom: 1px solid #333; }
        .client-section label { display: block; font-size: 0.8rem; color: #888; margin-bottom: 5px; }
        .client-input-group { display: flex; gap: 10px; }
        .client-input-group input { flex: 1; padding: 10px; background: #2c2c2c; border: 1px solid #444; border-radius: 5px; color: white; }
        .client-info { margin-top: 10px; font-size: 0.9rem; display: none; background: #2c2c2c; padding: 10px; border-radius: 5px;}
        
        .cart-items { flex: 1; overflow-y: auto; padding: 20px; }
        .cart-item { display: flex; justify-content: space-between; margin-bottom: 15px; border-bottom: 1px dashed #333; padding-bottom: 10px; }
        .cart-item-info h4 { font-size: 0.9rem; margin-bottom: 5px; }
        .cart-controls { display: flex; align-items: center; gap: 10px; margin-top: 5px; }
        .cart-btn { background: #333; color: white; border: none; width: 24px; height: 24px; border-radius: 4px; cursor: pointer; }
        .cart-item-total { font-weight: bold; font-size: 1rem; }

        .ticket-totals { padding: 20px; background: #151515; border-top: 1px solid #333; }
        .total-row { display: flex; justify-content: space-between; margin-bottom: 10px; color: #aaa; }
        .total-row.grand-total { font-size: 1.5rem; color: white; font-weight: bold; border-top: 1px solid #333; padding-top: 10px; margin-top: 10px; }
        .grand-total .val { color: var(--primary-red); }
        
        .btn-generate { width: 100%; padding: 15px; background: var(--primary-red); color: white; border: none; border-radius: 8px; font-size: 1.1rem; font-weight: bold; cursor: pointer; margin-top: 15px; }
        .btn-generate:hover { background: var(--primary-red-hover); }
    </style>
</head>
<body>

    <%- include('partials/sidebar', { page: 'pos' }) %>

    <div class="main-content">
        <%- include('partials/topbar', { pageTitle: 'Punto de Venta' }) %>

        <div class="pos-container">
            <!-- Izquierda: Productos -->
            <div class="products-section">
                <div class="filters">
                    <button class="filter-btn active">Todos</button>
                    <button class="filter-btn">Pastillas</button>
                    <button class="filter-btn">Discos</button>
                    <button class="filter-btn">Líquidos</button>
                    <button class="filter-btn">Reparación</button>
                </div>

                <div class="products-grid">
                    <% productos.forEach(p => { %>
                        <div class="product-card" data-id="<%= p.id %>" data-nombre="<%= p.nombre %>" data-precio="<%= p.precio %>" data-categoria="<%= p.categoria %>">
                            <% if(p.imagen) { %>
                                <div class="product-img" style="background-image: url('<%= p.imagen %>'); background-size: cover; background-position: center;"></div>
                            <% } else { %>
                                <div class="product-img">⚙️</div>
                            <% } %>
                            <div>
                                <div style="display:flex; justify-content: space-between; align-items:flex-start;">
                                    <div class="product-title"><%= p.nombre %></div>
                                    <div class="product-price">$<%= p.precio.toLocaleString('es-CO') %></div>
                                </div>
                                <div style="display:flex; justify-content: space-between; align-items:flex-end; margin-top: 10px;">
                                    <div class="product-stock" style="<%= p.cantidad <= 10 ? 'color: var(--primary-red);' : '' %>">
                                        STOCK: <%= p.cantidad %> UNIDADES
                                    </div>
                                    <button class="add-btn" onclick="addToCart(<%= p.id %>)">+</button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Derecha: Ticket -->
            <div class="ticket-section">
                <div class="ticket-header">
                    <h2>🧾 Ticket Actual</h2>
                    <span style="color: #666; font-size: 0.9rem;">#NUEVO</span>
                </div>

                <div class="client-section">
                    <label>CLIENTE ASIGNADO (Cédula)</label>
                    <div class="client-input-group">
                        <input type="text" id="cedula" placeholder="Ej. 1234567890">
                        <button class="btn btn-primary" onclick="buscarCliente()" style="padding: 10px;">Buscar</button>
                    </div>
                    <div id="client-info" class="client-info">
                        <!-- Info del cliente o formulario para nuevo cliente -->
                    </div>
                </div>

                <div class="cart-items" id="cart-items">
                    <!-- Items del carrito -->
                    <div style="text-align:center; color:#555; margin-top:50px;">El carrito está vacío</div>
                </div>

                <div class="ticket-totals">
                    <div class="total-row">
                        <span>Subtotal</span>
                        <span id="subtotal">$0.00</span>
                    </div>
                    <div class="total-row">
                        <span>IVA (16%)</span>
                        <span id="iva">$0.00</span>
                    </div>
                    <div class="total-row grand-total">
                        <span>Total</span>
                        <span class="val" id="total">$0.00</span>
                    </div>
                    <button class="btn-generate" onclick="generarTicket()">🖨️ Generar Ticket</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Script del POS -->
    <script src="/js/pos.js"></script>
</body>
</html>
