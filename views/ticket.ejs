<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        Ticket #<%= ticket.id %>
    </title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: #f5f5f5;
            padding: 40px;
            color: #222;
        }

        .ticket-container {
            width: 850px;
            margin: auto;
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 0 25px rgba(0, 0, 0, .12);
        }

        .ticket-header {
            background: #111;
            color: #fff;
            padding: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .ticket-header h1 {
            font-size: 32px;
            margin-bottom: 8px;
        }

        .ticket-header p {
            opacity: .8;
        }

        .ticket-info {
            padding: 30px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            border-bottom: 1px solid #eee;
        }

        .info-box h3 {
            margin-bottom: 15px;
            color: #e53935;
        }

        .info-box p {
            margin-bottom: 8px;
            color: #444;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #111;
            color: #fff;
        }

        th {
            padding: 16px;
            font-size: 14px;
            text-align: left;
        }

        td {
            padding: 18px 16px;
            border-bottom: 1px solid #eee;
        }

        tbody tr:hover {
            background: #fafafa;
        }

        .desc-col {
            font-weight: 600;
        }

        .sub-desc {
            display: block;
            margin-top: 4px;
            font-size: 12px;
            color: #888;
            font-weight: normal;
        }

        .totals-section {
            display: flex;
            justify-content: flex-end;
            padding: 35px;
        }

        .totals-box {
            width: 320px;
        }

        .t-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            font-size: 18px;
        }

        .grand {
            margin-top: 15px;
            padding-top: 18px;
            border-top: 2px solid #222;
            font-size: 24px;
            font-weight: bold;
        }

        .grand .val {
            color: #000;
        }

        .footer {
            text-align: center;
            padding: 25px;
            background: #fafafa;
            color: #666;
            font-size: 14px;
        }

        .actions {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 25px;
        }

        .btn {
            padding: 12px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            text-decoration: none;
            color: #fff;
        }

        .btn-print {
            background: #111;
        }

        .btn-back {
            background: #e53935;
        }

        @media print {

            body {
                background: #fff;
                padding: 0;
            }

            .actions {
                display: none;
            }

            .ticket-container {
                box-shadow: none;
                width: 100%;
            }
        }
    </style>

</head>

<body>

    <div class="ticket-container">

        <!-- HEADER -->

        <div class="ticket-header">

            <div>

                <h1>
                    SOLO FRENOS
                </h1>

                <p>
                    Sistema POS Automotriz
                </p>

            </div>

            <div style="text-align:right;">

                <h2>
                    TICKET #<%= ticket.id.toString().padStart(5,'0') %>
                </h2>

                <p>
                    <%= new Date(ticket.fecha).toLocaleString('es-CO') %>
                </p>

            </div>

        </div>


        <!-- INFO -->

        <div class="ticket-info">

            <div class="info-box">

                <h3>
                    Cliente
                </h3>

                <p>
                    <strong>Nombre:</strong>
                    <%= ticket.cliente_nombre || 'Consumidor Final' %>
                </p>

                <p>
                    <strong>Cédula:</strong>
                    <%= ticket.cedula || 'N/A' %>
                </p>

                <p>
                    <strong>Teléfono:</strong>
                    <%= ticket.telefono || 'N/A' %>
                </p>

            </div>


            <div class="info-box">

                <h3>
                    Vendedor
                </h3>

                <p>
                    <strong>Atendido por:</strong>
                    <%= ticket.vendedor || 'Administrador' %>
                </p>

                <p>
                    <strong>Método:</strong>
                    Efectivo
                </p>

            </div>

        </div>


        <!-- TABLA -->

        <table>

            <thead>

                <tr>

                    <th>
                        Producto
                    </th>

                    <th style="text-align:center;">
                        Cant.
                    </th>

                    <th style="text-align:right;">
                        Precio
                    </th>

                    <th style="text-align:right;">
                        Subtotal
                    </th>

                </tr>

            </thead>


            <tbody>

                <% let subtotal_sum=0; %>

                    <% detalles.forEach(d=> { %>

                        <% let row_sub=d.cantidad * d.precio; subtotal_sum +=row_sub; %>

                            <tr>

                                <td class="desc-col">

                                    <%= d.producto_nombre %>

                                        <span class="sub-desc">
                                            Cod: P-<%= d.producto_id.toString().padStart(3,'0') %>
                                        </span>

                                </td>

                                <td style="text-align:center;">

                                    <%= d.cantidad %>

                                </td>

                                <td style="text-align:right;">

                                    $<%= Math.round(d.precio).toLocaleString('es-CO') %>

                                </td>

                                <td style="text-align:right; font-weight:bold;">

                                    $<%= Math.round(row_sub).toLocaleString('es-CO') %>

                                </td>

                            </tr>

                            <% }) %>

            </tbody>

        </table>


        <!-- TOTALES -->

        <div class="totals-section">

            <div class="totals-box">

                <div class="t-row">

                    <span>
                        Subtotal
                    </span>

                    <span>
                        $<%= Math.round(subtotal_sum).toLocaleString('es-CO') %>
                    </span>

                </div>


                <div class="t-row">

                    <span>
                        IVA (16%)
                    </span>

                    <span>
                        $<%= Math.round(subtotal_sum * 0.16).toLocaleString('es-CO') %>
                    </span>

                </div>


                <div class="t-row grand">

                    <span>
                        TOTAL
                    </span>

                    <span class="val">
                        $<%= Math.round(ticket.total).toLocaleString('es-CO') %>
                    </span>

                </div>

            </div>

        </div>


        <!-- FOOTER -->

        <div class="footer">

            Gracias por confiar en
            <strong>
                Solo Frenos
            </strong>

            <br><br>

            Sistema POS Automotriz

        </div>

    </div>


    <!-- BOTONES -->

    <div class="actions">

        <button class="btn btn-print" onclick="window.print()">
            🖨 Imprimir
        </button>

        <a href="/pos" class="btn btn-back">
            ← Volver
        </a>

    </div>

</body>

</html>